# Copy this file to .env and fill in your values

# Database Configuration
POSTGRES_DB=lmw_database
POSTGRES_USER=lmw_user
POSTGRES_PASSWORD=your_postgres_password_here

MONGO_INITDB_ROOT_USERNAME=lmw_user
MONGO_INITDB_ROOT_PASSWORD=your_mongo_password_here
MONGO_INITDB_DATABASE=lmw_mongo

# Security
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# VLLM Configuration
VLLM_4B_URL=http://itservices-gpurack.iiit.ac.in:8001/v1
VLLM_4B_MODEL=./Qwen3-4B-Thinking-2507-Q4_K_M.gguf
VLLM_1_7B_URL=http://localhost:8002/v1
VLLM_1_7B_MODEL=./finetune_qwen3_1.7B.gguf
VLLM_TIMEOUT=300
VLLM_RETRIES=2

# Service URLs (usually don't need to change)
SME_SERVICE_URL=http://sme:8000
LEARNER_SERVICE_URL=http://learner:8002
INSTRUCTOR_SERVICE_URL=http://instructor:8003

# Ports
POSTGRES_PORT=5432
MONGODB_PORT=27017
