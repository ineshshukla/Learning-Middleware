FROM node:20-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy package files
COPY package.json pnpm-lock.yaml* ./

# Install dependencies
RUN pnpm i --no-frozen-lockfile

# Copy the rest (but in dev, this is mostly ignored due to volume mount)
COPY . .

EXPOSE 3000

# Dev server with hot reload
CMD ["pnpm", "dev"]
